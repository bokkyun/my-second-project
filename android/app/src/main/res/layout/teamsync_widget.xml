            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/mcell_21" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:gravity="center" android:textSize="11sp" />
            <TextView android:id="@+id/mcell_22" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:gravity="center" android:textSize="11sp" />
