            android:orientation="horizontal">
            <TextView android:id="@+id/mcell_28" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:gravity="center" android:textSize="11sp" />
            <TextView android:id="@+id/mcell_29" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:gravity="center" android:textSize="11sp" />
